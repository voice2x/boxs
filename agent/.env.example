# LLM 配置 (llama.cpp llama-server)
# 启动命令: llama-server -m ~/models/Qwen3-8B-Q4_K_M.gguf -c 4096 -ngl 99 --port 8080
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=local

# 如果用 Ollama，改为:
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen3:8b

# 日志级别
RUST_LOG=info

# Agent HTTP 服务端口（避开 llama-server:8080、boxs-server:8000）
# cargo run 读取此端口启动 POST /api/chat 服务（绑定 0.0.0.0）
AGENT_PORT=8081
